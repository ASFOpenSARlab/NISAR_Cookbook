 Add the current CRS to the DataArray\nepsg = gcov.getProjectionEpsg()\nda = da.rio.write_crs(f\"EPSG:{epsg}\", inplace=True)\n\n# Set the y and x coords as spatial dimensions\nda = da.rio.set_spatial_dims(x_dim=\"x\", y_dim=\"y\", inplace=True)\n\n# reproject the data\nda_reproj = da.rio.reproject(\"EPSG:4326\", inplace=True)\nda_reproj","key":"nBhUFkipx8"},{"type":"outputs","id":"B3VlZwpMjPCIZRYwIeHIz","children":[],"key":"FOSLGhoQuz"}],"key":"t7O4AkffKf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"da_reproj.spatial_ref","key":"CxjOZyKBA0"},{"type":"outputs","id":"Grr7nO6v3q6u-FjW1zWcW","children":[],"key":"oY745vPtBq"}],"key":"x7ZySs0egy"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"6. Calculate statistics and transformations on the data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"dpuE58Bo7I"}],"identifier":"id-6-calculate-statistics-and-transformations-on-the-data","label":"6. Calculate statistics and transformations on the data","html_id":"id-6-calculate-statistics-and-transformations-on-the-data","implicit":true,"key":"gltw2yIim7"},{"type":"heading","depth":3,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"As a loaded HDF5 dataset, you can call many ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"j7a4NiYdHb"},{"type":"inlineCode","value":"numpy","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"S5OSslvpex"},{"type":"text","value":" functions directly on the data.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xd2JHMBnPm"}],"identifier":"as-a-loaded-hdf5-dataset-you-can-call-many-numpy-functions-directly-on-the-data","label":"As a loaded HDF5 dataset, you can call many nu